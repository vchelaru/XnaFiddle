<?xml version="1.0" encoding="utf-8"?>
<!--
  Hermetic restore for XnaFiddle. NuGet resolves package sources from the SOLUTION
  directory (and its parents) when restoring a solution, so any machine-level feed
  (e.g. a private GitHub Packages source) merges in unless cleared here. That is
  normally harmless for XnaFiddle (it does not use central package management), but it
  breaks the sibling ShadowDusk projects referenced for in-browser shader support
  (issue #26): ShadowDusk DOES use central package management, and CPM + more than one
  ambient source raises NU1507. ShadowDusk's own hermetic nuget.config is ignored under
  a XnaFiddle.sln restore because ShadowDusk lives outside the solution's directory tree.

  Pin restore to nuget.org and map every package to it (clearing inherited sources) so
  the build resolves identically regardless of machine-level feeds. Every XnaFiddle
  dependency (and every ShadowDusk dependency) is published on nuget.org, so this loses
  nothing and makes the build reproducible for all contributors and CI.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
