<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>XnaFiddle</RootNamespace>
    <AssemblyName>XnaFiddle</AssemblyName>
    <DefineConstants>$(DefineConstants);BLAZORGL</DefineConstants>
    <KniPlatform>BlazorGL</KniPlatform>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
    <SkipAposShapeContent>true</SkipAposShapeContent>
    <!-- Preserve all public APIs for Roslyn runtime compilation -->
    <TrimMode>partial</TrimMode>
  </PropertyGroup>

  <!-- Assemblies that must not be trimmed (user code compiles against them at runtime) -->
  <ItemGroup>
    <TrimmerRootAssembly Include="Xna.Framework" />
    <TrimmerRootAssembly Include="Xna.Framework.Graphics" />
    <TrimmerRootAssembly Include="Xna.Framework.Content" />
    <TrimmerRootAssembly Include="Xna.Framework.Audio" />
    <TrimmerRootAssembly Include="Xna.Framework.Media" />
    <TrimmerRootAssembly Include="Xna.Framework.Input" />
    <TrimmerRootAssembly Include="Xna.Framework.Game" />
    <TrimmerRootAssembly Include="Xna.Framework.Devices" />
    <TrimmerRootAssembly Include="Xna.Framework.Storage" />
    <TrimmerRootAssembly Include="Xna.Framework.XR" />
    <TrimmerRootAssembly Include="Kni.Platform" />
    <TrimmerRootAssembly Include="KniGum" />
    <TrimmerRootAssembly Include="GumCommon" />
    <TrimmerRootAssembly Include="Apos.Shapes.KNI" />
    <TrimmerRootAssembly Include="KNI.Extended" />
  </ItemGroup>

  <ItemGroup Condition=" '$(TargetFramework)' == 'net8.0' ">
    <PackageReference Include="Apos.Shapes.KNI" Version="0.6.8" />
    <PackageReference Include="Gum.KNI" Version="2026.3.9.1" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="8.0.17" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="8.0.17" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.14.0" />
    <PackageReference Include="MetadataReferenceService.BlazorWasm" Version="0.0.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Submodules\KniSB\Platforms\Kni.Platform.Blazor.GL.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Examples\**" />
    <EmbeddedResource Include="Examples\*.cs" />
  </ItemGroup>

</Project>
