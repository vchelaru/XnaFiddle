@page "/"
@inject IJSRuntime JsRuntime
@inject HttpClient Http
@inject CompilationService Compiler
@inject IntellisenseService Intellisense
@inject NavigationManager Navigation
@inject LibraryRegistry LibraryRegistry
@implements IDisposable

<PageTitle>XnaFiddle</PageTitle>

@if (_embedMode)
{
    <div id="monacoContainer" style="display:none; width:0; height:0; position:absolute;"></div>
}

@if (!_embedMode)
{
<div id="editorPanel" style="
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: calc(45vw - 3px);
    background: #1e1e1e;
    display: flex;
    flex-direction: column;
    overflow: hidden;">

    <div style="padding: 6px 12px; background: #2d2d2d; display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
        @if (_isCompiling)
        {
            <button @onclick="StopCompilation"
                    style="padding: 4px 14px; background: #e04040; color: #fff; border: none; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 5px;">
                <i class="codicon codicon-debug-stop"></i>
                Stop
            </button>
        }
        else
        {
            <button @onclick="CompileAndRun"
                    style="padding: 4px 14px; background: #0e639c; color: white; border: none; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 5px;">
                <i class="codicon codicon-play"></i>
                @(_game != null ? "Restart" : "Run")
            </button>
            @if (_game != null)
            {
                <button @onclick="StopGame"
                        style="padding: 4px 14px; background: #e04040; color: #fff; border: none; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 5px;">
                    <i class="codicon codicon-debug-stop"></i>
                    Stop
                </button>
            }
        }
        <button @onclick="OpenExampleBrowser"
                style="padding: 4px 8px; background: @(_exampleBrowserOpen ? "#0e639c" : "#3c3c3c"); color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 5px;
                       user-select: none; -webkit-user-select: none;">
            <i class="codicon codicon-library"></i>
            @(string.IsNullOrEmpty(_selectedExample) ? "Examples" : _selectedExample)
        </button>
        <button @onclick="OpenShareDialog" title="Share"
                style="padding: 4px 8px; background: @(_shareOpen ? "#0e639c" : "#3c3c3c"); color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center;">
            <i class="codicon codicon-link-external"></i>
        </button>
        <button @onclick="() => _assetsOpen = !_assetsOpen" title="@(_assets.Count > 0 ? $"Assets ({_assets.Count})" : "Assets")"
                style="padding: 4px 8px; background: @(_assets.Count > 0 ? "#2d5a2d" : "#3c3c3c"); color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center; position: relative;">
            <i class="codicon codicon-file-media"></i>
            @if (_assets.Count > 0)
            {
                <span style="position: absolute; top: 1px; right: 1px; font-size: 9px; color: #89d185; line-height: 1;">@_assets.Count</span>
            }
        </button>
        <button @onclick="() => { _gistOpen = !_gistOpen; if (!_gistOpen) _gistCodeCopied = false; }" title="Gist"
                style="padding: 4px 8px; background: @(_gistOpen ? "#0e639c" : "#3c3c3c"); color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center;">
            <i class="codicon codicon-github"></i>
        </button>
        <button @onclick="() => _exportOpen = !_exportOpen" title="Export Project"
                style="padding: 4px 8px; background: @(_exportOpen ? "#0e639c" : "#3c3c3c"); color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center;">
            <i class="codicon codicon-package"></i>
        </button>
        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <span style="color: @_statusColor; font-size: 13px;">@_statusMessage</span>
            @if (_staleAssets)
            {
                <button @onclick="ForceRefresh"
                        style="padding: 2px 8px; background: #0e639c; color: #fff; border: 1px solid #007acc;
                               cursor: pointer; font-size: 12px; margin-left: 4px;">
                    Refresh
                </button>
            }
        }
        <a href="https://github.com/vchelaru/XnaFiddle" target="_blank" title="About XnaFiddle"
           style="margin-left: auto; padding: 4px 8px; background: #3c3c3c; color: #d4d4d4;
                  border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center;
                  text-decoration: none; opacity: 0.7; transition: opacity 0.15s;"
           onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
            <i class="codicon codicon-question"></i>
        </a>
        <span style="color: #555; font-size: 11px; white-space: nowrap;" title="Version">built @BuildTimeLocal</span>
    </div>

    @if (_isCompiling)
    {
        var assemblyDone = _compileTotal > 0 && _compileProgress >= _compileTotal;
        var pct = assemblyDone ? 100 : (_compileTotal > 0 ? (90 * _compileProgress / _compileTotal) : 0);
        var barTransition = assemblyDone ? "width 4s ease-in" : "none";
        var elapsed = (DateTime.Now - _compileStartTime).TotalSeconds;
        <div style="height: 3px; background: #1a1a1a; flex-shrink: 0;">
            <div style="height: 100%; width: @(pct)%; background: #007acc; transition: @barTransition; position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; height: 100%; width: 40%;
                            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
                            animation: compileshimmer 1.5s infinite linear; will-change: transform;"></div>
            </div>
        </div>
        <div style="padding: 2px 12px; background: #252526; font-size: 11px; color: #888; flex-shrink: 0;">
            @if (assemblyDone)
            {
                <text>Compiling... &nbsp;·&nbsp; <span id="compileTimer">0.0s</span></text>
            }
            else if (_compileTotal > 0)
            {
                <text>Resolving assemblies @_compileProgress / @_compileTotal &nbsp;·&nbsp; <span id="compileTimer">0.0s</span></text>
            }
            else
            {
                <text>Starting... &nbsp;·&nbsp; <span id="compileTimer">0.0s</span></text>
            }
            @if (!_hasCompiledOnce)
            {
                <text> &nbsp;·&nbsp; <span style="color: #666;">first compile takes longer</span></text>
            }
        </div>
    }

    @if (_assetsOpen)
    {
        <div style="padding: 4px 12px; background: #252526; border-bottom: 1px solid #333; flex-shrink: 0;
                    display: flex; flex-direction: column; gap: 4px; min-height: 28px;">
            <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 6px;">
                @if (_assets.Count == 0)
                {
                    <span style="color: #888; font-size: 12px; font-style: italic;">Drop files onto the canvas or add by URL &mdash; supported: <span style="font-style: normal; color: #9cdcfe;">@string.Join(" \u00A0", SupportedAssetExtensions)</span></span>
                }
                else
                {
                    @foreach (var asset in _assets)
                    {
                        var name = asset.FileName;
                        var nameNoExt = System.IO.Path.GetFileNameWithoutExtension(name);
                        var loadCode = $"Content.Load<Texture2D>(\"{nameNoExt}\")";
                        var sizeKb = asset.Size < 1024 ? asset.Size + " B" : (asset.Size / 1024) + " KB";
                        <span style="display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px;
                                    background: #3c3c3c; border-radius: 3px; font-size: 12px; color: #d4d4d4;">
                            <span @onclick="() => CopyToClipboard(loadCode)"
                                  style="color: @(!string.IsNullOrEmpty(asset.SourceUrl) ? "#dcdcaa" : "#9cdcfe"); cursor: pointer;"
                                  title="@(!string.IsNullOrEmpty(asset.SourceUrl) ? asset.SourceUrl + " — click to copy load code" : "Click to copy load code")">@name</span>
                            <span style="color: #888;">@sizeKb</span>
                            @if (asset.FntTextures != null)
                            {
                                foreach (var tex in asset.FntTextures)
                                {
                                    if (!InMemoryContentManager.Files.ContainsKey(tex))
                                    {
                                        <span style="color: #f48771;" title="Missing texture — drop this file onto the canvas">&#9888; @tex</span>
                                    }
                                }
                            }
                            <button @onclick="() => RemoveAsset(name)"
                                    style="background: none; border: none; color: #888; cursor: pointer;
                                           font-size: 14px; padding: 0 2px; line-height: 1;"
                                    title="Remove">&times;</button>
                        </span>
                    }
                }
            </div>
            <div style="display: flex; align-items: center; gap: 6px;">
                <input @bind="_assetUrlInput" @onkeydown="OnAssetUrlKeyDown" placeholder="@($"https://raw.githubusercontent.com/...  ({SupportedExtensionsDisplay})")"
                       style="flex: 1; padding: 2px 8px; background: #3c3c3c; color: #d4d4d4;
                              border: 1px solid #555; font-size: 12px; font-family: Consolas, monospace;" />
                <button @onclick="FetchAssetFromUrl" disabled="@_isFetchingAssetUrl"
                        style="padding: 2px 10px; background: #0e639c; color: white; border: none;
                               cursor: pointer; font-size: 12px; white-space: nowrap;">
                    @(_isFetchingAssetUrl ? "Fetching..." : "Add URL")
                </button>
            </div>
        </div>
    }

    @if (_gistOpen)
    {
        <div style="background: #252526; border-bottom: 1px solid #333; flex-shrink: 0;">
            <div style="padding: 6px 12px; display: flex; flex-direction: column; gap: 6px;">
                <div style="color: #6a9955; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Export to Gist</div>
                @if (!_gistCodeCopied)
                {
                    <div style="color: #888; font-size: 12px; line-height: 1.6;">
                        This will copy your code to the clipboard and open <b style="color: #d4d4d4;">gist.github.com</b> in a new tab.
                        Paste your code there, create the gist, then come back and paste the URL below to link it.
                    </div>
                    <button @onclick="OpenGistSite"
                            style="padding: 4px 14px; background: #3c3c3c; color: #d4d4d4; border: 1px solid #555;
                                   cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 5px; align-self: flex-start;">
                        <i class="codicon codicon-github"></i> Copy code to clipboard &amp; open gist.github.com
                    </button>
                }
                else
                {
                    <div style="color: #888; font-size: 12px; line-height: 1.6;">
                        Code copied! Paste it into gist.github.com, create the gist, then copy the URL from your browser and paste it in the Import box below.
                    </div>
                }
            </div>
            <div style="border-top: 1px solid #333; padding: 6px 12px; display: flex; flex-direction: column; gap: 6px;">
                <div style="color: #9cdcfe; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Import from Gist</div>
                <div style="display: flex; align-items: center; gap: 6px;">
                    <input @bind="_gistInput" @onkeydown="OnGistInputKeyDown" placeholder="https://gist.github.com/user/abc123  or  abc123"
                           style="flex: 1; padding: 3px 8px; background: #3c3c3c; color: #d4d4d4;
                                  border: 1px solid #555; font-size: 13px; font-family: Consolas, monospace;" />
                    <button @onclick="LoadGistFromInput" disabled="@_isCompiling"
                            style="padding: 3px 12px; background: #0e639c; color: white; border: none;
                                   cursor: pointer; font-size: 13px; white-space: nowrap;">@(_gistCodeCopied ? "Verify & Link" : "Load & Run")</button>
                </div>
            </div>
        </div>
    }

    @if (_exportOpen)
    {
        <div style="background: #252526; border-bottom: 1px solid #333; flex-shrink: 0; font-size: 12px; color: #d4d4d4; padding: 8px 12px; display: flex; flex-direction: column; gap: 8px;">
            @* Row 1: Runtime + Platform *@
            <div style="display: flex; align-items: flex-start; gap: 20px;">
                @* Runtime radio buttons *@
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <span style="color: #aaa; margin-bottom: 2px;">Runtime:</span>
                    <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; color: #ccc;">
                        <input type="radio" name="exportRuntime" checked="@(_exportRuntime == ExportRuntime.Kni)"
                               @onchange="() => SetExportRuntime(ExportRuntime.Kni)"
                               style="accent-color: #0e639c;" />
                        KNI
                    </label>
                    <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; color: #ccc;">
                        <input type="radio" name="exportRuntime" checked="@(_exportRuntime == ExportRuntime.MonoGame)"
                               @onchange="() => SetExportRuntime(ExportRuntime.MonoGame)"
                               style="accent-color: #0e639c;" />
                        MonoGame
                    </label>
                </div>

                @* Platform checkboxes *@
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <span style="color: #aaa; margin-bottom: 2px;">Platform:</span>
                    @foreach (var (platform, label) in new[] {
                        (ExportPlatform.DesktopGL,  "DesktopGL (Windows/Linux/macOS)"),
                        (ExportPlatform.WindowsDX,  "WindowsDX (Windows)"),
                        (ExportPlatform.Android,    "Android"),
                        (ExportPlatform.BlazorGL,   "BlazorGL (Browser)")
                    })
                    {
                        var p = platform;
                        if (p == ExportPlatform.BlazorGL && _exportRuntime == ExportRuntime.MonoGame)
                            continue;
                        <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; color: #ccc;">
                            <input type="checkbox" checked="@(_selectedPlatforms.Contains(p))"
                                   @onchange="() => TogglePlatform(p)"
                                   style="accent-color: #0e639c;" />
                            @label
                        </label>
                    }
                    @if (_selectedPlatforms.Count >= 2)
                    {
                        <span style="color: #569cd6; font-size: 11px; margin-top: 2px;">
                            Multiple platforms selected — export will generate a shared library project plus one project per platform.
                        </span>
                    }
                </div>
            </div>

            @* Row 2: Project name + Export button *@
            <div style="display: flex; align-items: center; gap: 12px;">
                <span style="color: #aaa;">Project name:</span>
                <input type="text" @bind="_exportProjectName" @bind:event="oninput"
                       @onkeydown="OnExportNameKeyDown"
                       style="background: #3c3c3c; color: #d4d4d4; border: 1px solid #555; padding: 3px 8px;
                              font-size: 12px; font-family: inherit; width: 150px;" />
                <button @onclick="ExportProject" disabled="@(_isExporting || string.IsNullOrWhiteSpace(_exportProjectName) || _selectedPlatforms.Count == 0)"
                        style="margin-left: auto; padding: 5px 20px; background: #0e639c; color: white; border: none; cursor: pointer;
                               font-size: 13px; border-radius: 3px; display: flex; align-items: center; gap: 5px;">
                    <i class="codicon codicon-package"></i>
                    @(_isExporting ? "Exporting..." : "Export")
                </button>
            </div>
        </div>
    }

    @if (_shareOpen)
    {
        <div style="background: #252526; border-bottom: 1px solid #333; flex-shrink: 0; font-size: 12px; color: #d4d4d4;">
            <div style="padding: 6px 12px; display: flex; flex-direction: column; gap: 8px;">

                @* Mode toggle *@
                <div style="display: flex; gap: 0; align-self: flex-start;">
                    <button @onclick='() => _shareAsSnippet = false'
                            style="padding: 3px 12px; cursor: pointer; border: 1px solid #555; border-right: none;
                                   background: @(!_shareAsSnippet ? "#0e639c" : "#3c3c3c");
                                   color: @(!_shareAsSnippet ? "white" : "#aaa"); font-size: 12px;">
                        Code
                    </button>
                    <button @onclick='() => _shareAsSnippet = true'
                            style="padding: 3px 12px; cursor: pointer; border: 1px solid #555;
                                   background: @(_shareAsSnippet ? "#0e639c" : "#3c3c3c");
                                   color: @(_shareAsSnippet ? "white" : "#aaa"); font-size: 12px;">
                        Snippet
                    </button>
                </div>

                @if (!_shareAsSnippet)
                {
                    @* Code mode: URL + copy *@
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <input readonly value="@_shareCodeUrl"
                               style="flex: 1; padding: 3px 8px; background: #1e1e1e; color: #9cdcfe;
                                      border: 1px solid #555; font-size: 12px; font-family: Consolas, monospace;" />
                        <button @onclick="CopyShareUrl"
                                style="padding: 3px 10px; background: #3c3c3c; color: #d4d4d4;
                                       border: 1px solid #555; cursor: pointer; white-space: nowrap; font-size: 12px;">
                            <i class="codicon codicon-copy"></i> Copy
                        </button>
                        <span style="color: #555; font-size: 11px; text-align: center; line-height: 1.3;">@(_shareCodeUrl?.Length)<br/>chars</span>
                    </div>
                }
                else
                {
                    @if (_revertResult == null || !_revertResult.Success)
                    {
                        <div style="color: #f48771;">@(_revertResult?.ErrorMessage ?? "Could not parse code as a Game subclass.")</div>
                    }
                    else
                    {
                        @* Preset flags — read-only, just showing what was detected *@
                        <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; color: #888;">
                            <span>Presets:</span>
                            <label style="display: flex; align-items: center; gap: 4px; opacity: @(_revertResult.IsGum ? "1" : "0.35"); color: #d4d4d4;">
                                <input type="checkbox" checked="@_revertResult.IsGum" disabled /> Gum
                            </label>
                            <label style="display: flex; align-items: center; gap: 4px; opacity: @(_revertResult.IsAposShapes ? "1" : "0.35"); color: #d4d4d4;">
                                <input type="checkbox" checked="@_revertResult.IsAposShapes" disabled /> Apos.Shapes
                            </label>
                            <label style="display: flex; align-items: center; gap: 4px; opacity: @(_revertResult.IsMonoGameExtended ? "1" : "0.35"); color: #d4d4d4;">
                                <input type="checkbox" checked="@_revertResult.IsMonoGameExtended" disabled /> MonoGame.Extended
                            </label>
                        </div>

                        @* Content section checkboxes — interactive *@
                        <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; color: #888;">
                            <span>Include:</span>
                            <label style="display: flex; align-items: center; gap: 4px; opacity: @(!string.IsNullOrWhiteSpace(_revertResult.Members) ? "1" : "0.35"); color: #d4d4d4; cursor: @(!string.IsNullOrWhiteSpace(_revertResult.Members) ? "pointer" : "default");">
                                <input type="checkbox" @bind="_snipMembers" @bind:after="RecomputeSnippetPreview" disabled="@(string.IsNullOrWhiteSpace(_revertResult.Members))" /> Members
                            </label>
                            <label style="display: flex; align-items: center; gap: 4px; opacity: @(!string.IsNullOrWhiteSpace(_revertResult.Initialize) ? "1" : "0.35"); color: #d4d4d4; cursor: @(!string.IsNullOrWhiteSpace(_revertResult.Initialize) ? "pointer" : "default");">
                                <input type="checkbox" @bind="_snipInitialize" @bind:after="RecomputeSnippetPreview" disabled="@(string.IsNullOrWhiteSpace(_revertResult.Initialize))" /> Initialize
                            </label>
                            <label style="display: flex; align-items: center; gap: 4px; opacity: @(!string.IsNullOrWhiteSpace(_revertResult.LoadContent) ? "1" : "0.35"); color: #d4d4d4; cursor: @(!string.IsNullOrWhiteSpace(_revertResult.LoadContent) ? "pointer" : "default");">
                                <input type="checkbox" @bind="_snipLoadContent" @bind:after="RecomputeSnippetPreview" disabled="@(string.IsNullOrWhiteSpace(_revertResult.LoadContent))" /> LoadContent
                            </label>
                            <label style="display: flex; align-items: center; gap: 4px; opacity: @(!string.IsNullOrWhiteSpace(_revertResult.Update) ? "1" : "0.35"); color: #d4d4d4; cursor: @(!string.IsNullOrWhiteSpace(_revertResult.Update) ? "pointer" : "default");">
                                <input type="checkbox" @bind="_snipUpdate" @bind:after="RecomputeSnippetPreview" disabled="@(string.IsNullOrWhiteSpace(_revertResult.Update))" /> Update
                            </label>
                            <label style="display: flex; align-items: center; gap: 4px; opacity: @(!string.IsNullOrWhiteSpace(_revertResult.Draw) ? "1" : "0.35"); color: #d4d4d4; cursor: @(!string.IsNullOrWhiteSpace(_revertResult.Draw) ? "pointer" : "default");">
                                <input type="checkbox" @bind="_snipDraw" @bind:after="RecomputeSnippetPreview" disabled="@(string.IsNullOrWhiteSpace(_revertResult.Draw))" /> Draw
                            </label>
                        </div>

                        @* Live JSON preview *@
                        @if (_snippetPreviewJson != null)
                        {
                            <pre style="margin: 0; padding: 6px 8px; background: #1e1e1e; color: #ce9178;
                                        font-size: 11px; font-family: Consolas, monospace; overflow: auto;
                                        max-height: 160px; white-space: pre-wrap; word-break: break-all;
                                        border: 1px solid #333;">@_snippetPreviewJson</pre>
                        }

                        @* Live URL + copy *@
                        <div style="display: flex; align-items: center; gap: 6px;">
                            <input readonly value="@_snippetPreviewUrl"
                                   style="flex: 1; padding: 3px 8px; background: #1e1e1e; color: #9cdcfe;
                                          border: 1px solid #555; font-size: 12px; font-family: Consolas, monospace;" />
                            <button @onclick="CopyShareUrl"
                                    style="padding: 3px 10px; background: #3c3c3c; color: #d4d4d4;
                                           border: 1px solid #555; cursor: pointer; white-space: nowrap; font-size: 12px;">
                                <i class="codicon codicon-copy"></i> Copy
                            </button>
                            <span style="color: #555; font-size: 11px; text-align: center; line-height: 1.3;">@(_snippetPreviewUrl?.Length)<br/>chars</span>
                        </div>
                    }
                }

            </div>
        </div>
    }

    <div style="flex: 1; min-height: 0; position: relative; overflow: hidden;">
        <div id="monacoContainer" style="width: 100%; height: 100%;"></div>
        @if (!Intellisense.IsReady)
        {
            <div style="position: absolute; top: 6px; right: 56px; z-index: 5;
                        background: #2d2d2d; color: #dcdcaa; border: 1px solid #444;
                        border-radius: 3px; padding: 3px 8px; font-size: 11px;
                        font-style: italic; opacity: 0.85; pointer-events: none;
                        display: flex; align-items: center; gap: 6px;"
                 title="Roslyn is warming up — completions will be limited until this finishes.">
                <span class="xf-intellisense-spinner" style="display: inline-block; width: 8px; height: 8px;
                        border: 1.5px solid #dcdcaa; border-top-color: transparent;
                        border-radius: 50%; animation: xf-spin 0.8s linear infinite;"></span>
                Loading IntelliSense&hellip;
            </div>
            <style>
                @@keyframes xf-spin { to { transform: rotate(360deg); } }
            </style>
        }
        <button @onclick="CopyEditorContent" title="Copy code"
                style="position: absolute; top: 6px; right: 20px; z-index: 5;
                       background: #2d2d2d; color: #888; border: 1px solid #444;
                       border-radius: 3px; padding: 3px 6px; cursor: pointer; font-size: 14px;
                       opacity: 0.7; transition: opacity 0.15s;"
                onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
            <i class="codicon codicon-copy"></i>
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_diagnosticsOutput))
    {
        <div id="diagnosticsSplitter" style="height: 4px; background: #007acc; cursor: ns-resize; flex-shrink: 0;"></div>
        <pre id="diagnosticsPanel" style="margin: 0; padding: 8px 12px; background: #1a1a1a; color: @_diagnosticsColor;
                    font-size: 12px; font-family: Consolas, monospace; overflow: auto;
                    height: 100px; flex-shrink: 0; white-space: pre-wrap; word-wrap: break-word;">@_diagnosticsOutput</pre>
    }

    @if (_exampleBrowserOpen)
    {
        <div @onclick="() => _exampleBrowserOpen = false"
             style="position: absolute; inset: 0; background: rgba(0,0,0,0.5); z-index: 100;
                    display: flex; align-items: center; justify-content: center;">
            <div @onclick:stopPropagation="true"
                 style="background: #252526; border: 1px solid #444; border-radius: 6px;
                        width: 90%; max-width: 600px; min-height: 350px; max-height: 80%; display: flex; flex-direction: column;
                        box-shadow: 0 8px 32px rgba(0,0,0,0.5); overflow: hidden;">
                <div style="padding: 10px 16px; background: #2d2d2d; border-bottom: 1px solid #333;
                            display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;">
                    <span style="color: #d4d4d4; font-size: 14px; font-weight: 500;">Examples</span>
                    <button @onclick="() => _exampleBrowserOpen = false"
                            style="background: none; border: none; color: #888; cursor: pointer; font-size: 16px; padding: 0 4px;">&times;</button>
                </div>
                <div style="display: flex; flex: 1; min-height: 0; overflow: hidden;">
                    @* Category sidebar *@
                    <div style="min-width: 140px; max-width: 160px; background: #1e1e1e; border-right: 1px solid #333;
                                overflow-y: auto; flex-shrink: 0; padding: 6px 0;">
                        @foreach (var category in ExampleGallery.Categories)
                        {
                            @if (category == ExampleGallery.Categories[0])
                            {
                                @* nothing before the first category *@
                            }
                            else if (category == ExampleGallery.LibraryCategories[0])
                            {
                                <div style="border-top: 1px solid #444; margin: 6px 10px;"></div>
                            }
                            var isActive = category == _selectedCategory;
                            <div @onclick="() => _selectedCategory = category"
                                 style="padding: 6px 14px; cursor: pointer; font-size: 13px;
                                        color: @(isActive ? "#fff" : "#aaa");
                                        background: @(isActive ? "#0e639c" : "transparent");
                                        border-left: 3px solid @(isActive ? "#007acc" : "transparent");
                                        transition: background 0.1s;"
                                 onmouseover="@(isActive ? "" : "this.style.background='#2a2a2a'")"
                                 onmouseout="@(isActive ? "" : "this.style.background='transparent'")">
                                @category
                            </div>
                        }
                    </div>
                    @* Example cards *@
                    <div style="flex: 1; overflow-y: auto; padding: 10px;">
                        @foreach (var example in ExampleGallery.Catalog)
                        {
                            if (example.Category != _selectedCategory) continue;
                            var isSelected = example.Name == _selectedExample;
                            <div @onclick="() => SelectExample(example.Name)"
                                 style="padding: 10px 14px; margin-bottom: 6px; cursor: pointer;
                                        background: @(isSelected ? "#0e639c33" : "#2d2d2d");
                                        border: 1px solid @(isSelected ? "#0e639c" : "#3c3c3c");
                                        border-radius: 4px; transition: border-color 0.1s, background 0.1s;"
                                 onmouseover="this.style.borderColor='#007acc'"
                                 onmouseout="this.style.borderColor='@(isSelected ? "#0e639c" : "#3c3c3c")'">
                                <div style="color: #d4d4d4; font-size: 13px; font-weight: 500;">@example.Name</div>
                                <div style="color: #888; font-size: 12px; margin-top: 3px;">@example.Description</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
} @* end @if (!_embedMode) *@

@if (!_embedMode)
{
<div id="splitter" style="
    position: fixed;
    top: 0;
    left: calc(45vw - 3px);
    width: 5px;
    height: 100vh;
    background: #007acc;
    cursor: ew-resize;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;">
    <button @onclick="ToggleLayout"
            title="@(_layoutVertical ? "Switch to left/right layout" : "Switch to top/bottom layout")"
            style="position: absolute; width: 20px; height: 20px; padding: 0;
                   background: #007acc; color: white; border: none; cursor: pointer;
                   border-radius: 50%; font-size: 11px;
                   display: flex; align-items: center; justify-content: center;
                   opacity: 0.6; transition: opacity 0.15s; z-index: 11;"
            onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'"
            onmousedown="event.stopPropagation()">
        <i class="codicon @(_layoutVertical ? "codicon-split-horizontal" : "codicon-split-vertical")" style="font-size: 11px;"></i>
    </button>
</div>
} @* end @if (!_embedMode) *@

<div id="canvasHolder" style="
    background: #000;
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: @(_embedMode ? "0" : "calc(45vw + 2px)");">
    <canvas id="theCanvas" style="touch-action:none;"></canvas>
    @if (_embedMode && _isCompiling)
    {
        var embedAssemblyDone = _compileTotal > 0 && _compileProgress >= _compileTotal;
        var embedPct = embedAssemblyDone ? 100 : (_compileTotal > 0 ? (90 * _compileProgress / _compileTotal) : 0);
        var embedBarTransition = embedAssemblyDone ? "width 4s ease-in" : "none";
        <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
                    z-index: 20; pointer-events: none; background: rgba(0,0,0,0.75);">
            <div style="color: #9cdcfe; font-family: 'Segoe UI', sans-serif; font-size: 16px; font-weight: 300; letter-spacing: 0.05em; margin-bottom: 16px;">XnaFiddle</div>
            <div style="width: 200px; height: 3px; background: #222; border-radius: 2px; overflow: hidden; margin-bottom: 10px;">
                <div style="height: 100%; width: @(embedPct)%; background: #007acc; transition: @embedBarTransition; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: 0; left: 0; height: 100%; width: 40%;
                                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
                                animation: compileshimmer 1.5s infinite linear; will-change: transform;"></div>
                </div>
            </div>
            <div style="color: #888; font-family: 'Segoe UI', sans-serif; font-size: 12px;">
                @if (embedAssemblyDone)
                {
                    <text>Compiling... &nbsp;·&nbsp; <span id="compileTimer">0.0s</span></text>
                }
                else if (_compileTotal > 0)
                {
                    <text>Loading @_compileProgress / @_compileTotal</text>
                }
                else
                {
                    <text>Starting...</text>
                }
            </div>
            @if (!_hasCompiledOnce)
            {
                <div style="color: #555; font-family: 'Segoe UI', sans-serif; font-size: 11px; margin-top: 6px;">first compile takes longer</div>
            }
        </div>
    }
    @if (_embedMode && !string.IsNullOrEmpty(_editUrl))
    {
        <a href="@_editUrl" target="_blank"
           style="position: absolute; top: 8px; right: 8px; z-index: 15;
                  padding: 3px 8px; background: rgba(0,0,0,0.5); color: #aaa;
                  text-decoration: none; font-size: 11px; font-family: 'Segoe UI', sans-serif;
                  border: 1px solid rgba(255,255,255,0.12); border-radius: 3px;
                  display: flex; align-items: center; gap: 4px;
                  opacity: 0.55; transition: opacity 0.15s;"
           onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.55'">
            <i class="codicon codicon-edit" style="font-size: 11px;"></i> Edit in XnaFiddle
        </a>
    }
    @if (_game == null && !_isCompiling && !_profileSwitchPending)
    {
        <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none;">
            <div style="text-align: center; color: #888; font-family: 'Segoe UI', sans-serif; font-size: 15px; line-height: 1.8; user-select: none;">
                <div style="font-size: 22px; color: #aaa; margin-bottom: 12px;">Welcome to XnaFiddle</div>
                Pick an example from the dropdown, or write your own XNA-style C# code,<br/>
                then click the Run button to compile and run.
                <div style="margin-top: 16px; pointer-events: auto;">
                    <button @onclick="CompileAndRun"
                            style="padding: 6px 18px; background: #0e639c; color: white; border: none; cursor: pointer; font-size: 14px; display: inline-flex; align-items: center; gap: 6px;">
                        <i class="codicon codicon-play"></i>
                        Run
                    </button>
                </div>
                <div style="margin-top: 20px; font-size: 12px; color: #555; pointer-events: auto;">
                    <span style="color: #4a4a4a; margin-right: 8px;">Available libraries:</span>
                    <a href="https://docs.flatredball.com/gum/code/about" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">Gum</a>
                    <span style="margin: 0 8px; color: #444;">·</span>
                    <a href="https://www.monogameextended.net/" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">MonoGame.Extended</a>
                    <span style="margin: 0 8px; color: #444;">·</span>
                    <a href="https://github.com/Apostolique/Apos.Shapes" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">Apos.Shapes</a>
                    <span style="margin: 0 8px; color: #444;">·</span>
                    <a href="https://github.com/FontStashSharp/FontStashSharp" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">FontStashSharp</a>
                    <span style="margin: 0 8px; color: #444;">·</span>
                    <a href="https://github.com/nkast/Aether.Physics2D" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">Aether.Physics2D</a>
                    <span style="margin: 0 8px; color: #444;">·</span>
                    <a href="https://mlem.ellpeck.de" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">MLEM (Ui and Extended)</a>
                </div>
                <a href="https://github.com/kniEngine/kni" target="_blank"
                   style="display: inline-flex; align-items: center; gap: 8px; margin-top: 24px;
                          color: #555; text-decoration: none; font-size: 12px;
                          border: 1px solid #2a2a2a; border-radius: 4px; padding: 6px 12px;
                          transition: border-color 0.15s, color 0.15s; pointer-events: auto;"
                   onmouseover="this.style.borderColor='#444';this.style.color='#999'"
                   onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#555'">
                    <img src="kni-logo.png" style="width: 20px; height: 20px; border-radius: 3px;" alt="KNI" />
                    Built with KNI &mdash; Learn more
                </a>
            </div>
        </div>
    }
</div>

@* Profile-switch confirmation (#25). A canvas can't change WebGL version in place, so switching
   between Reach/HiDef requires a full page reload. We surface that explicitly — and warn about
   any uploaded files that won't survive the reload — instead of reloading silently. *@
@if (_profileSwitchPending)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 200;
                display: flex; align-items: center; justify-content: center;">
        <div style="background: #252526; border: 1px solid #444; border-radius: 6px;
                    width: 90%; max-width: 460px; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
                    overflow: hidden; font-family: 'Segoe UI', sans-serif;">
            <div style="padding: 10px 16px; background: #2d2d2d; border-bottom: 1px solid #333;">
                <span style="color: #dcdcaa; font-size: 14px; font-weight: 500;">Graphics mode switch required</span>
            </div>
            <div style="padding: 16px; color: #d4d4d4; font-size: 13px; line-height: 1.6;">
                @if (_assetsLostOnReload.Count > 0)
                {
                    <p style="margin: 0 0 6px; color: #f48771; font-weight: 600;">
                        @(_assetsLostOnReload.Count == 1 ? "This uploaded file" : "These uploaded files")
                        will be lost — not loaded from a URL, so it can't be restored after the reload:
                    </p>
                    <ul style="margin: 0 0 6px; padding-left: 22px; color: #f48771;">
                        @foreach (var name in _assetsLostOnReload)
                        {
                            <li>@name</li>
                        }
                    </ul>
                    <p style="margin: 0 0 12px; color: #888; font-size: 12px;">
                        Tip: Cancel and re-add them via &ldquo;from URL&rdquo; if you want them to survive the switch.
                    </p>
                }
                <p style="margin: 0 0 10px;">
                    This game uses <b>@ProfileName(_pendingProfile)</b>, but the page is currently
                    running in <b>@ProfileName(_canvasProfile ?? Microsoft.Xna.Framework.Graphics.GraphicsProfile.Reach)</b>.
                </p>
                <p style="margin: 0;">
                    A browser canvas can't change graphics mode once it has started, so XnaFiddle must
                    <b>reload the whole page</b> to switch. Your code is kept, and assets loaded from a
                    URL are re-fetched automatically.
                </p>
            </div>
            <div style="padding: 12px 16px; background: #2d2d2d; border-top: 1px solid #333;
                        display: flex; justify-content: flex-end; gap: 8px;">
                <button @onclick="CancelProfileSwitch"
                        style="padding: 5px 14px; background: #3c3c3c; color: #d4d4d4; border: 1px solid #555;
                               cursor: pointer; font-size: 13px;">Cancel</button>
                <button @onclick="ConfirmProfileSwitch"
                        style="padding: 5px 14px; background: #0e639c; color: white; border: none;
                               cursor: pointer; font-size: 13px;">Reload &amp; Run</button>
            </div>
        </div>
    </div>
}
