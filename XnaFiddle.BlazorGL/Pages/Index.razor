@page "/"
@inject IJSRuntime JsRuntime
@inject HttpClient Http
@inject CompilationService Compiler
@inject NavigationManager Navigation

<PageTitle>XnaFiddle</PageTitle>

@if (_embedMode)
{
    <div id="monacoContainer" style="display:none; width:0; height:0; position:absolute;"></div>
}

@if (!_embedMode)
{
<div id="editorPanel" style="
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: calc(45vw - 3px);
    background: #1e1e1e;
    display: flex;
    flex-direction: column;
    overflow: hidden;">

    <div style="padding: 6px 12px; background: #2d2d2d; display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
        <button @onclick="CompileAndRun" disabled="@_isCompiling"
                style="padding: 4px 14px; background: #0e639c; color: white; border: none; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 5px;">
            <i class="codicon @(_isCompiling ? "codicon-loading codicon-modifier-spin" : "codicon-play")"></i>
            @(_isCompiling ? "Running..." : "Run")
        </button>
        <select @onchange="OnExampleSelected" value="@_selectedExample"
                style="padding: 3px 8px; background: #3c3c3c; color: #d4d4d4; border: 1px solid #555;
                       font-size: 13px; cursor: pointer; user-select: none; -webkit-user-select: none;
                       max-width: 140px;">
            <option value="">Examples...</option>
            @foreach (var name in ExampleGallery.Names)
            {
                <option value="@name">@name</option>
            }
        </select>
        <button @onclick="ShareAsCode" title="Share as URL"
                style="padding: 4px 8px; background: #3c3c3c; color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center;">
            <i class="codicon codicon-link-external"></i>
        </button>
        <button @onclick="() => _assetsOpen = !_assetsOpen" title="@(_assets.Count > 0 ? $"Assets ({_assets.Count})" : "Assets")"
                style="padding: 4px 8px; background: @(_assets.Count > 0 ? "#2d5a2d" : "#3c3c3c"); color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center; position: relative;">
            <i class="codicon codicon-file-media"></i>
            @if (_assets.Count > 0)
            {
                <span style="position: absolute; top: 1px; right: 1px; font-size: 9px; color: #89d185; line-height: 1;">@_assets.Count</span>
            }
        </button>
        <button @onclick="() => { _gistOpen = !_gistOpen; if (!_gistOpen) _gistCodeCopied = false; }" title="Gist"
                style="padding: 4px 8px; background: @(_gistOpen ? "#0e639c" : "#3c3c3c"); color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center;">
            <i class="codicon codicon-github"></i>
        </button>
        <button @onclick="ToggleRunLocally" title="Run Locally"
                style="padding: 4px 8px; background: #3c3c3c; color: #d4d4d4;
                       border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center;">
            <i class="codicon codicon-desktop-download"></i>
        </button>
        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <span style="color: @_statusColor; font-size: 13px;">@_statusMessage</span>
        }
        <a href="https://github.com/vchelaru/XnaFiddle" target="_blank" title="About XnaFiddle"
           style="margin-left: auto; padding: 4px 8px; background: #3c3c3c; color: #d4d4d4;
                  border: 1px solid #555; cursor: pointer; font-size: 14px; display: flex; align-items: center;
                  text-decoration: none; opacity: 0.7; transition: opacity 0.15s;"
           onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
            <i class="codicon codicon-question"></i>
        </a>
        <span style="color: #555; font-size: 11px; white-space: nowrap;" title="Version">built @BuildTimeLocal</span>
    </div>

    @if (_isCompiling)
    {
        var assemblyDone = _compileTotal > 0 && _compileProgress >= _compileTotal;
        var pct = assemblyDone ? 100 : (_compileTotal > 0 ? (90 * _compileProgress / _compileTotal) : 0);
        var barTransition = assemblyDone ? "width 4s ease-in" : "none";
        var elapsed = (DateTime.Now - _compileStartTime).TotalSeconds;
        <div style="height: 3px; background: #1a1a1a; flex-shrink: 0;">
            <div style="height: 100%; width: @(pct)%; background: #007acc; transition: @barTransition; position: relative; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; height: 100%; width: 40%;
                            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
                            animation: compileshimmer 1.5s infinite linear; will-change: transform;"></div>
            </div>
        </div>
        <div style="padding: 2px 12px; background: #252526; font-size: 11px; color: #888; flex-shrink: 0;">
            @if (assemblyDone)
            {
                <text>Compiling... &nbsp;·&nbsp; <span id="compileTimer">0.0s</span></text>
            }
            else if (_compileTotal > 0)
            {
                <text>Resolving assemblies @_compileProgress / @_compileTotal &nbsp;·&nbsp; <span id="compileTimer">0.0s</span></text>
            }
            else
            {
                <text>Starting... &nbsp;·&nbsp; <span id="compileTimer">0.0s</span></text>
            }
            @if (!_hasCompiledOnce)
            {
                <text> &nbsp;·&nbsp; <span style="color: #666;">first compile takes longer</span></text>
            }
        </div>
    }

    @if (_assetsOpen)
    {
        <div style="padding: 4px 12px; background: #252526; border-bottom: 1px solid #333; flex-shrink: 0;
                    display: flex; flex-wrap: wrap; align-items: center; gap: 6px; min-height: 28px;">
            @if (_assets.Count == 0)
            {
                <span style="color: #888; font-size: 12px; font-style: italic;">Drop files onto the canvas &mdash; supported: <span style="font-style: normal; color: #9cdcfe;">.png &nbsp;.fnt</span></span>
            }
            else
            {
                @foreach (var asset in _assets)
                {
                    var name = asset.FileName;
                    var nameNoExt = System.IO.Path.GetFileNameWithoutExtension(name);
                    var loadCode = $"Content.Load<Texture2D>(\"{nameNoExt}\")";
                    var sizeKb = asset.Size < 1024 ? asset.Size + " B" : (asset.Size / 1024) + " KB";
                    <span style="display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px;
                                background: #3c3c3c; border-radius: 3px; font-size: 12px; color: #d4d4d4;">
                        <span @onclick="() => CopyToClipboard(loadCode)"
                              style="color: #9cdcfe; cursor: pointer;"
                              title="Click to copy load code">@name</span>
                        <span style="color: #888;">@sizeKb</span>
                        @if (asset.FntTextures != null)
                        {
                            foreach (var tex in asset.FntTextures)
                            {
                                if (!InMemoryContentManager.Files.ContainsKey(tex))
                                {
                                    <span style="color: #f48771;" title="Missing texture — drop this file onto the canvas">&#9888; @tex</span>
                                }
                            }
                        }
                        <button @onclick="() => RemoveAsset(name)"
                                style="background: none; border: none; color: #888; cursor: pointer;
                                       font-size: 14px; padding: 0 2px; line-height: 1;"
                                title="Remove">&times;</button>
                    </span>
                }
            }
        </div>
    }

    @if (_gistOpen)
    {
        <div style="background: #252526; border-bottom: 1px solid #333; flex-shrink: 0;">
            <div style="padding: 6px 12px; display: flex; flex-direction: column; gap: 6px;">
                <div style="color: #6a9955; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Export to Gist</div>
                @if (!_gistCodeCopied)
                {
                    <div style="color: #888; font-size: 12px; line-height: 1.6;">
                        This will copy your code to the clipboard and open <b style="color: #d4d4d4;">gist.github.com</b> in a new tab.
                        Paste your code there, create the gist, then come back and paste the URL below to link it.
                    </div>
                    <button @onclick="OpenGistSite"
                            style="padding: 4px 14px; background: #3c3c3c; color: #d4d4d4; border: 1px solid #555;
                                   cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 5px; align-self: flex-start;">
                        <i class="codicon codicon-github"></i> Copy code to clipboard &amp; open gist.github.com
                    </button>
                }
                else
                {
                    <div style="color: #888; font-size: 12px; line-height: 1.6;">
                        Code copied! Paste it into gist.github.com, create the gist, then copy the URL from your browser and paste it in the Import box below.
                    </div>
                }
            </div>
            <div style="border-top: 1px solid #333; padding: 6px 12px; display: flex; flex-direction: column; gap: 6px;">
                <div style="color: #9cdcfe; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Import from Gist</div>
                <div style="display: flex; align-items: center; gap: 6px;">
                    <input @bind="_gistInput" @onkeydown="OnGistInputKeyDown" placeholder="https://gist.github.com/user/abc123  or  abc123"
                           style="flex: 1; padding: 3px 8px; background: #3c3c3c; color: #d4d4d4;
                                  border: 1px solid #555; font-size: 13px; font-family: Consolas, monospace;" />
                    <button @onclick="LoadGistFromInput" disabled="@_isCompiling"
                            style="padding: 3px 12px; background: #0e639c; color: white; border: none;
                                   cursor: pointer; font-size: 13px; white-space: nowrap;">@(_gistCodeCopied ? "Verify & Link" : "Load & Run")</button>
                </div>
            </div>
        </div>
    }

    @if (_runLocallyOpen)
    {
        <div style="background: #252526; border-bottom: 1px solid #333; flex-shrink: 0; font-size: 12px; color: #d4d4d4;">
            <div style="padding: 5px 12px; color: #aaa; border-bottom: 1px solid #2e2e2e;">
                @if (_runLocallyPackages.Count == 0)
                {
                    <text>Copy this code into your game's <span style="color: #9cdcfe;">.cs</span> file. No extra NuGet packages are needed.</text>
                }
                else
                {
                    <text>Copy this code into your game's <span style="color: #9cdcfe;">.cs</span> file, then add the following NuGet packages to your project.
                    <span style="color: #dcdcaa;">Yellow = KNI</span> &nbsp;·&nbsp; <span style="color: #9cdcfe;">Blue = MonoGame</span> &nbsp;·&nbsp; Click a package to copy the <span style="color: #9cdcfe;">dotnet add package</span> command.</text>
                }
            </div>
            @if (_runLocallyPackages.Count > 0)
            {
                <div style="padding: 5px 12px; display: flex; flex-wrap: wrap; align-items: center; gap: 8px;">
                    @foreach (var pkg in _runLocallyPackages)
                    {
                        var kniCmd = "dotnet add package " + pkg.KniPackage;
                        var mgCmd  = "dotnet add package " + pkg.MonoGamePackage;
                        <span style="display: inline-flex; align-items: center; gap: 5px;">
                            <span style="color: #888;">@pkg.Feature:</span>
                            <span @onclick="() => CopyToClipboard(kniCmd)"
                                  style="color: #dcdcaa; cursor: pointer; background: #3c3c3c; padding: 1px 6px; border-radius: 3px;"
                                  title="KNI — click to copy command">@pkg.KniPackage</span>
                            <span style="color: #555;">or</span>
                            <span @onclick="() => CopyToClipboard(mgCmd)"
                                  style="color: #9cdcfe; cursor: pointer; background: #3c3c3c; padding: 1px 6px; border-radius: 3px;"
                                  title="MonoGame — click to copy command">@pkg.MonoGamePackage</span>
                        </span>
                    }
                </div>
            }
        </div>
    }

    <div style="flex: 1; min-height: 0; position: relative; overflow: hidden;">
        <div id="monacoContainer" style="width: 100%; height: 100%;"></div>
        <button @onclick="CopyEditorContent" title="Copy code"
                style="position: absolute; top: 6px; right: 20px; z-index: 5;
                       background: #2d2d2d; color: #888; border: 1px solid #444;
                       border-radius: 3px; padding: 3px 6px; cursor: pointer; font-size: 14px;
                       opacity: 0.7; transition: opacity 0.15s;"
                onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
            <i class="codicon codicon-copy"></i>
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_diagnosticsOutput))
    {
        <div id="diagnosticsSplitter" style="height: 4px; background: #007acc; cursor: ns-resize; flex-shrink: 0;"></div>
        <pre id="diagnosticsPanel" style="margin: 0; padding: 8px 12px; background: #1a1a1a; color: @_diagnosticsColor;
                    font-size: 12px; font-family: Consolas, monospace; overflow: auto;
                    height: 100px; flex-shrink: 0; white-space: pre-wrap; word-wrap: break-word;">@_diagnosticsOutput</pre>
    }
</div>
} @* end @if (!_embedMode) *@

@if (!_embedMode)
{
<div id="splitter" style="
    position: fixed;
    top: 0;
    left: calc(45vw - 3px);
    width: 5px;
    height: 100vh;
    background: #007acc;
    cursor: ew-resize;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;">
    <button @onclick="ToggleLayout"
            title="@(_layoutVertical ? "Switch to left/right layout" : "Switch to top/bottom layout")"
            style="position: absolute; width: 20px; height: 20px; padding: 0;
                   background: #007acc; color: white; border: none; cursor: pointer;
                   border-radius: 50%; font-size: 11px;
                   display: flex; align-items: center; justify-content: center;
                   opacity: 0.6; transition: opacity 0.15s; z-index: 11;"
            onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'"
            onmousedown="event.stopPropagation()">
        <i class="codicon @(_layoutVertical ? "codicon-split-horizontal" : "codicon-split-vertical")" style="font-size: 11px;"></i>
    </button>
</div>
} @* end @if (!_embedMode) *@

<div id="canvasHolder" style="
    background: #000;
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: @(_embedMode ? "0" : "calc(45vw + 2px)");">
    <canvas id="theCanvas" style="touch-action:none;"></canvas>
    @if (_embedMode && _isCompiling)
    {
        var embedAssemblyDone = _compileTotal > 0 && _compileProgress >= _compileTotal;
        var embedPct = embedAssemblyDone ? 100 : (_compileTotal > 0 ? (90 * _compileProgress / _compileTotal) : 0);
        var embedBarTransition = embedAssemblyDone ? "width 4s ease-in" : "none";
        <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
                    z-index: 20; pointer-events: none; background: rgba(0,0,0,0.75);">
            <div style="color: #9cdcfe; font-family: 'Segoe UI', sans-serif; font-size: 16px; font-weight: 300; letter-spacing: 0.05em; margin-bottom: 16px;">XnaFiddle</div>
            <div style="width: 200px; height: 3px; background: #222; border-radius: 2px; overflow: hidden; margin-bottom: 10px;">
                <div style="height: 100%; width: @(embedPct)%; background: #007acc; transition: @embedBarTransition; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: 0; left: 0; height: 100%; width: 40%;
                                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
                                animation: compileshimmer 1.5s infinite linear; will-change: transform;"></div>
                </div>
            </div>
            <div style="color: #888; font-family: 'Segoe UI', sans-serif; font-size: 12px;">
                @if (embedAssemblyDone)
                {
                    <text>Compiling... &nbsp;·&nbsp; <span id="compileTimer">0.0s</span></text>
                }
                else if (_compileTotal > 0)
                {
                    <text>Loading @_compileProgress / @_compileTotal</text>
                }
                else
                {
                    <text>Starting...</text>
                }
            </div>
            @if (!_hasCompiledOnce)
            {
                <div style="color: #555; font-family: 'Segoe UI', sans-serif; font-size: 11px; margin-top: 6px;">first compile takes longer</div>
            }
        </div>
    }
    @if (_embedMode && !string.IsNullOrEmpty(_editUrl))
    {
        <a href="@_editUrl" target="_blank"
           style="position: absolute; top: 8px; right: 8px; z-index: 15;
                  padding: 3px 8px; background: rgba(0,0,0,0.5); color: #aaa;
                  text-decoration: none; font-size: 11px; font-family: 'Segoe UI', sans-serif;
                  border: 1px solid rgba(255,255,255,0.12); border-radius: 3px;
                  display: flex; align-items: center; gap: 4px;
                  opacity: 0.55; transition: opacity 0.15s;"
           onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.55'">
            <i class="codicon codicon-edit" style="font-size: 11px;"></i> Edit in XnaFiddle
        </a>
    }
    @if (_game == null && !_isCompiling)
    {
        <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none;">
            <div style="text-align: center; color: #888; font-family: 'Segoe UI', sans-serif; font-size: 15px; line-height: 1.8; user-select: none;">
                <div style="font-size: 22px; color: #aaa; margin-bottom: 12px;">Welcome to XnaFiddle</div>
                Pick an example from the dropdown and click <span style="color: #9cdcfe;">Compile &amp; Run</span><br/>
                or write your own XNA-style C# code and compile.
                <div style="margin-top: 20px; font-size: 12px; color: #555; pointer-events: auto;">
                    <span style="color: #4a4a4a; margin-right: 8px;">Available libraries:</span>
                    <a href="https://docs.flatredball.com/gum/code/about" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">Gum</a>
                    <span style="margin: 0 8px; color: #444;">·</span>
                    <a href="https://www.monogameextended.net/" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">MonoGame.Extended</a>
                    <span style="margin: 0 8px; color: #444;">·</span>
                    <a href="https://github.com/Apostolique/Apos.Shapes" target="_blank"
                       style="color: #666; text-decoration: none;"
                       onmouseover="this.style.color='#999'" onmouseout="this.style.color='#666'">Apos.Shapes</a>
                </div>
            </div>
        </div>
    }
</div>
